database:
  uri: "postgresql://mas:maspass@mas-db:5432/mas"

default:
  clients:
    - client_id: "test_client_id"
      client_auth_method: "client_secret_basic"
      client_secret: "test_client_secret"
      redirect_uris:
        - "http://localhost:3000/callback"
      grant_types:
        - "authorization_code"
      response_types:
        - "code"
      scopes:
        - "openid"
        - "profile"
        - "phone_number"

  upstream_oauth:
    providers:
      - id: "gua_identity"
        issuer: "http://host.docker.internal:8080"
        client_id: "gua_identity_client"
        client_secret: "gua_identity_secret"
        scopes:
          - "openid"
          - "profile"
          - "phone_number"
        jwks_uri: "http://host.docker.internal:8080/oauth2/keys.json"